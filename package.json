{
	"name": "inclusive",
	"version": "1.0.9",
	"description": "An Accessible WordPress theme",
	"author": "Carolina Nymark",
	"license": "GPL-2.0-or-later",
	"devDependencies": {
		"@babel/core": "^7.29.0",
		"@babel/eslint-parser": "^7.28.6",
		"@typescript-eslint/eslint-plugin": "^8.46.1",
		"@typescript-eslint/parser": "^8.46.1",
		"@wordpress/eslint-plugin": "^24.3.0",
		"@wordpress/stylelint-config": "^23.33.0",
		"autoprefixer": "^10.4.27",
		"cssnano": "^7.1.3",
		"eslint": "^8.57.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-jest": "^29.15.0",
		"eslint-plugin-jsdoc": "^62.8.0",
		"eslint-plugin-jsx-a11y": "^6.10.2",
		"eslint-plugin-playwright": "^2.10.0",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^7.0.1",
		"npm-package-json-lint": "^9.0.0",
		"postcss-cli": "^11.0.1",
		"prettier": "^3.8.1",
		"rtlcss": "^4.3.0",
		"stylelint": "^16.24.0",
		"typescript": "^5.9.3"
	},
	"overrides": {
		"@typescript-eslint/typescript-estree": {
			"minimatch": "^9.0.7"
		},
		"minimatch": "^9.0.7"
	},
	"scripts": {
		"minify": "postcss assets/css/*css --no-map --dir assets/css/min/ --ext min.css",
		"blocks": "postcss assets/css/blocks/core/src/*css --no-map --dir assets/css/blocks/core/ --ext min.css",
		"rtl:minify": "postcss assets/css/*css --no-map --use rtlcss --dir assets/css/min/ --ext min-rtl.css",
		"rtl:blocks": "postcss assets/css/blocks/core/src/*css --no-map --use rtlcss --dir assets/css/blocks/core/ --ext min-rtl.css",
		"build:css": "npm run minify && npm run blocks && npm run rtl:minify && npm run rtl:blocks",
		"lint:css": "stylelint \"assets/css/**/*.css\" --config .stylelintrc.json",
		"lint:js": "eslint assets/js/customizer.js assets/js/nav.js assets/js/responsive-videos.js",
		"lint:pkg-json": "npmPkgJsonLint ."
	}
}
